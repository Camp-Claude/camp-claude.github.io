---
import BaseLayout from '../../layouts/BaseLayout.astro';

const STRIPE_PAYMENT_LINK = 'https://buy.stripe.com/REPLACE_WITH_PAYMENT_LINK';
---

<BaseLayout
  title="Foundations cohort"
  description="Four live sessions over four weeks. Build one real automation with a cohort of peers and direct coaching."
  activeNav="cohort"
>
  <section class="hero">
    <div>
      <div class="eyebrow">Camp Claude · Foundations</div>
      <h1>Four weeks. Four live sessions. <em>One real automation</em> you'll actually use.</h1>
      <p class="dek">The guided experience of the open curriculum — with a cohort of peers, live coaching, and a finish line that isn't optional.</p>
      <div class="meta">
        <span>4 × 60 min live sessions</span><span class="dot">·</span>
        <span>12–18 learners per cohort</span><span class="dot">·</span>
        <span>Next cohort starts May 12, 2026</span>
      </div>
    </div>

    <aside class="price-card">
      <div class="label">Foundations cohort</div>
      <div class="amount"><span class="currency">$</span>299</div>
      <div class="amount-note">One-time · Four-week program</div>
      <ul>
        <li>4 live 60-minute sessions</li>
        <li>Private cohort community</li>
        <li>Session recordings + workbook</li>
        <li>One completed automation by week 4</li>
        <li>30-day post-cohort Q&amp;A access</li>
      </ul>
      <a class="buy-btn" href={STRIPE_PAYMENT_LINK}>Enroll now — $299</a>
      <div class="stripe-note">Secure checkout · Stripe</div>
      <div class="guarantee"><strong>30-day guarantee.</strong> If you attend the first two sessions and decide it's not for you, full refund.</div>
    </aside>
  </section>

  <section class="strip cream">
    <div class="inner">
      <div class="section-eyebrow">Who this is for</div>
      <h2 class="section-h2">Built for <em>AI-fluent professionals</em>, not beginners.</h2>
      <p class="lead">You've used ChatGPT. You've prompted. You know what a chatbot does. This cohort starts where ChatGPT stops.</p>
    </div>
  </section>

  <section class="strip">
    <div class="inner">
      <div class="section-eyebrow">The four sessions</div>
      <h2 class="section-h2">Each one stacks on <em>the last</em>.</h2>

      <div class="sessions">
        <div class="session">
          <div class="num">Session <span class="big">01</span></div>
          <div><h4>The Three Doors</h4><span class="outcome">Outcome: Claude installed, mental map clear</span></div>
          <p>Chat, Cowork, Code — the three surfaces and which door to use for what. Five settings that actually matter.</p>
        </div>
        <div class="session">
          <div class="num">Session <span class="big">02</span></div>
          <div><h4>Chat, Projects &amp; Context</h4><span class="outcome">Outcome: One live Chat Project with real work</span></div>
          <p>Organize ongoing work in Chat Projects. Artifacts. Context window mechanics. Model selection.</p>
        </div>
        <div class="session">
          <div class="num">Session <span class="big">03</span></div>
          <div><h4>Skills, Connectors &amp; Plugins</h4><span class="outcome">Outcome: One connector + one skill installed</span></div>
          <p>The three levers. Install Gmail or Calendar live. Write your first <code>CLAUDE.md</code> skill.</p>
        </div>
        <div class="session">
          <div class="num">Session <span class="big">04</span></div>
          <div><h4>A Taste of Cowork + Your First Automation</h4><span class="outcome">Outcome: One scheduled automation running</span></div>
          <p>Open Cowork. Build the morning inbox triage (or your equivalent) and schedule it. Leave with an automation that runs tomorrow.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="strip ink">
    <div class="inner">
      <div class="final-cta">
        <div class="section-eyebrow center">Next cohort</div>
        <h2>May 12, 2026.<br/>Tuesdays, 7–8pm ET.<br/><em>15 seats.</em></h2>
        <p>Four weeks of live sessions. One real automation. A cohort of peers who'll still be talking to each other six months from now.</p>
        <a href={STRIPE_PAYMENT_LINK} class="big-btn">Enroll — $299</a>
        <p class="tiny">Secure checkout · Stripe · 30-day guarantee</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { max-width: 1280px; margin: 0 auto; padding: 72px 48px 56px; display: grid; grid-template-columns: minmax(0, 1fr) 400px; gap: 72px; align-items: start; }
  .eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); margin-bottom: 24px; }
  h1 { font-family: var(--serif); font-weight: 400; font-size: 76px; line-height: 0.98; letter-spacing: -0.02em; color: var(--ink); margin: 0 0 24px; text-wrap: balance; }
  h1 em { color: var(--rust); font-style: italic; }
  .dek { font-family: var(--serif); font-style: italic; font-size: 26px; line-height: 1.3; color: var(--ink-soft); margin: 0 0 32px; max-width: 48ch; text-wrap: pretty; }
  .meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); padding-top: 24px; border-top: 1px solid var(--line); }
  .meta span { margin-right: 28px; }
  .meta .dot { color: var(--rust); margin: 0 12px; }

  .price-card { background: var(--ink); color: var(--paper); border-radius: 3px; padding: 36px 32px; position: sticky; top: 24px; }
  .price-card .label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust-soft); margin-bottom: 20px; }
  .price-card .amount { font-family: var(--serif); font-size: 88px; line-height: 1; letter-spacing: -0.03em; font-style: italic; color: var(--paper); }
  .price-card .amount .currency { font-size: 36px; vertical-align: super; color: var(--rust-soft); margin-right: 6px; }
  .price-card .amount-note { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(244,238,227,0.6); margin: 12px 0 28px; }
  .price-card ul { margin: 0 0 28px; padding: 0; list-style: none; }
  .price-card li { padding: 10px 0; font-size: 14px; line-height: 1.4; border-top: 1px solid rgba(244,238,227,0.12); display: flex; gap: 12px; }
  .price-card li::before { content: "+"; color: var(--rust-soft); font-family: var(--mono); font-size: 14px; }
  .price-card .buy-btn { display: block; width: 100%; text-align: center; background: var(--paper); color: var(--ink); padding: 16px 20px; border-radius: 2px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; font-weight: 500; text-decoration: none; }
  .price-card .buy-btn:hover { background: var(--rust-soft); color: var(--ink); text-decoration: none; }
  .price-card .stripe-note { font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; color: rgba(244,238,227,0.5); text-align: center; margin-top: 14px; }
  .price-card .guarantee { font-size: 13px; line-height: 1.5; color: rgba(244,238,227,0.72); margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(244,238,227,0.12); }

  .strip { padding: 80px 48px; border-top: 1px solid var(--line); }
  .strip .inner { max-width: 1280px; margin: 0 auto; }
  .strip.cream { background: var(--cream); }
  .strip.ink { background: var(--ink); color: var(--paper); border-top: none; }
  .section-eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); margin-bottom: 18px; }
  .section-eyebrow.center { text-align: center; }
  .strip.ink .section-eyebrow { color: var(--rust-soft); }
  .section-h2 { font-family: var(--serif); font-weight: 400; font-size: 52px; line-height: 1.02; letter-spacing: -0.02em; margin: 0 0 28px; text-wrap: balance; }
  .section-h2 em { color: var(--rust); font-style: italic; }
  .lead { max-width: 62ch; color: var(--ink-soft); font-size: 17px; }

  .sessions { margin-top: 40px; }
  .session { display: grid; grid-template-columns: 140px 1fr 2fr; gap: 48px; padding: 36px 0; border-top: 1px solid var(--line); align-items: baseline; }
  .session:last-child { border-bottom: 1px solid var(--line); }
  .session .num { font-family: var(--mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); }
  .session .num .big { display: block; font-family: var(--serif); font-style: italic; font-size: 64px; line-height: 1; letter-spacing: -0.02em; color: var(--ink); margin-top: 4px; text-transform: none; }
  .session h4 { font-family: var(--serif); font-weight: 400; font-size: 28px; line-height: 1.1; letter-spacing: -0.01em; margin: 0 0 10px; }
  .session p { font-size: 15px; line-height: 1.55; color: var(--ink-soft); margin: 0; max-width: 54ch; }
  .session .outcome { display: block; margin-top: 12px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sage); }

  .final-cta { text-align: center; max-width: 800px; margin: 0 auto; }
  .final-cta h2 { font-family: var(--serif); font-weight: 400; font-size: 64px; line-height: 1.02; letter-spacing: -0.02em; color: var(--paper); margin: 0 0 24px; font-style: italic; text-wrap: balance; }
  .final-cta h2 em { color: var(--rust-soft); font-style: italic; }
  .final-cta p { font-size: 18px; line-height: 1.55; color: rgba(244,238,227,0.72); margin: 0 0 36px; }
  .final-cta .big-btn { display: inline-block; background: var(--paper); color: var(--ink); padding: 18px 32px; border-radius: 2px; font-family: var(--mono); font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase; text-decoration: none; font-weight: 500; }
  .final-cta .big-btn:hover { background: var(--rust-soft); }
  .final-cta .tiny { margin-top: 24px; font-size: 13px; font-family: var(--mono); letter-spacing: 0.14em; color: rgba(244,238,227,0.4); }

  @media (max-width: 960px) {
    .hero { grid-template-columns: 1fr; gap: 40px; padding: 48px 24px; }
    h1 { font-size: 44px; }
    .dek { font-size: 21px; }
    .price-card { position: static; }
    .section-h2 { font-size: 36px; }
    .final-cta h2 { font-size: 40px; }
    .session { grid-template-columns: 1fr; gap: 12px; }
    .strip { padding: 48px 24px; }
  }
</style>
