---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const teachEntries = await getCollection('teach', ({ data }) => !data.draft);
  const refEntries = await getCollection('reference', ({ data }) => !data.draft);

  return [...teachEntries, ...refEntries].map(entry => ({
    params: { slug: (entry.data.canonicalSlug ?? entry.id).replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const sectionLabel = entry.data.section === 'reference' ? 'Reference' : 'Teach';
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  activeNav="learn"
>
  <div class="page">
    <article>
      <div class="breadcrumb">
        <a href="/learn">Learn</a><span class="sep">/</span>
        <a href={`/learn#${entry.data.section}`}>{sectionLabel}</a><span class="sep">/</span>
        <span>{entry.data.title}</span>
      </div>

      <h1 set:html={entry.data.title} />
      {entry.data.description && <p class="dek">{entry.data.description}</p>}
      <div class="meta">
        {entry.data.readTime && <span>{entry.data.readTime}</span>}
        {entry.data.module && <span>Module {String(entry.data.module).padStart(2, '0')}</span>}
        <span>Free · Open curriculum</span>
      </div>

      <div class="prose">
        <Content />
      </div>
    </article>

    <aside class="sidebar">
      <div class="sidebar-card dark">
        <div class="label">The guided experience</div>
        <h4>This reading is free.<br/>The <em>practice</em> isn't.</h4>
        <p>Reading the map takes minutes. Learning to live inside the three doors — with a cohort, live practice, and a graduation moment — takes four weeks.</p>
        <a href="/cohort" class="btn">Join Foundations — $299</a>
      </div>

      <div class="sidebar-card">
        <div class="label">Want to teach this?</div>
        <h4>Become a Camp Claude <em>facilitator</em>.</h4>
        <p>Everything on this site is open curriculum. Study the material, join a train-the-trainer, and run your own cohorts.</p>
        <a href="/facilitate" class="btn-ghost">Learn the pathway →</a>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .page { max-width: 1280px; margin: 0 auto; padding: 48px 48px 80px; display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 72px; align-items: start; }

  .breadcrumb { font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 28px; }
  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--rust); text-decoration: none; }
  .breadcrumb .sep { margin: 0 10px; opacity: 0.5; }

  h1 { font-family: var(--serif); font-weight: 400; font-size: 72px; line-height: 1; letter-spacing: -0.02em; color: var(--ink); margin: 0 0 20px; text-wrap: balance; }
  h1 :global(em) { color: var(--rust); font-style: italic; }

  .dek { font-family: var(--serif); font-style: italic; font-size: 28px; line-height: 1.3; color: var(--ink-soft); margin: 0 0 32px; max-width: 52ch; text-wrap: pretty; }

  .meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--line); }
  .meta span { margin-right: 28px; }

  /* Prose styles for rendered markdown */
  .prose :global(h2) { font-family: var(--serif); font-weight: 400; font-size: 40px; line-height: 1.1; letter-spacing: -0.015em; color: var(--ink); margin: 56px 0 20px; text-wrap: balance; }
  .prose :global(h2 em) { color: var(--rust); font-style: italic; }
  .prose :global(h3) { font-family: var(--serif); font-weight: 400; font-size: 26px; line-height: 1.2; letter-spacing: -0.01em; color: var(--ink); margin: 40px 0 14px; }
  .prose :global(p) { margin: 0 0 1.2em; max-width: 62ch; color: var(--ink-soft); }
  .prose :global(h1:first-child),
  .prose :global(h1:first-child + p),
  .prose :global(h1:first-child + p + p),
  .prose :global(h1:first-child + p + p + hr) { display: none; }
  .prose :global(ul), .prose :global(ol) { padding-left: 24px; max-width: 62ch; margin-bottom: 1.2em; }
  .prose :global(li) { margin-bottom: 10px; color: var(--ink-soft); }
  .prose :global(li strong) { color: var(--ink); font-weight: 500; }
  .prose :global(blockquote) { border-left: 3px solid var(--rust); padding: 8px 0 8px 24px; margin: 32px 0; font-family: var(--serif); font-style: italic; font-size: 22px; line-height: 1.4; color: var(--ink-soft); max-width: 56ch; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--line); margin: 48px 0; }
  .prose :global(a) { color: var(--rust); }
  .prose :global(code) { font-family: var(--mono); font-size: 14px; background: var(--cream); padding: 2px 6px; border-radius: 3px; border: 1px solid var(--line-soft); }
  .prose :global(pre) { background: var(--cream); padding: 16px 20px; border-radius: 4px; overflow-x: auto; border: 1px solid var(--line-soft); font-size: 13px; line-height: 1.5; }
  .prose :global(pre code) { background: none; border: none; padding: 0; }
  .prose :global(table) { border-collapse: collapse; margin: 20px 0; font-size: 14px; border: 1px solid var(--line); }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--line); padding: 10px 14px; text-align: left; vertical-align: top; }
  .prose :global(th) { background: var(--ink); color: var(--paper); font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500; }
  .prose :global(tr:nth-child(even) td) { background: var(--cream); }

  /* Sidebar */
  .sidebar { position: sticky; top: 32px; }
  .sidebar-card { background: var(--paper-soft); border: 1px solid var(--line); border-radius: 3px; padding: 28px; margin-bottom: 24px; }
  .sidebar-card.dark { background: var(--ink); color: var(--paper); border: none; }
  .sidebar-card .label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust); margin-bottom: 14px; }
  .sidebar-card.dark .label { color: var(--rust-soft); }
  .sidebar-card h4 { font-family: var(--serif); font-weight: 400; font-size: 24px; line-height: 1.15; letter-spacing: -0.01em; margin: 0 0 12px; }
  .sidebar-card h4 em { color: var(--rust); font-style: italic; }
  .sidebar-card.dark h4 em { color: var(--rust-soft); }
  .sidebar-card p { font-size: 14px; line-height: 1.5; color: var(--ink-soft); margin: 0 0 18px; }
  .sidebar-card.dark p { color: rgba(244,238,227,0.72); }
  .sidebar-card .btn { display: inline-block; background: var(--ink); color: var(--paper); padding: 10px 18px; border-radius: 2px; font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; text-decoration: none; }
  .sidebar-card.dark .btn { background: var(--paper); color: var(--ink); }
  .sidebar-card .btn:hover { background: var(--rust); text-decoration: none; }
  .sidebar-card.dark .btn:hover { background: var(--rust-soft); color: var(--ink); }
  .sidebar-card .btn-ghost { display: inline-block; padding: 8px 0; font-family: var(--mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--rust); border-bottom: 1px solid var(--rust); }

  @media (max-width: 900px) {
    .page { grid-template-columns: 1fr; padding: 24px; gap: 32px; }
    .sidebar { position: static; }
    h1 { font-size: 44px; }
    .dek { font-size: 22px; }
    .prose :global(h2) { font-size: 30px; }
  }
</style>
